# ══════════════════════════════════════════════════════════════════════════════
# POB System v2.0 — Production Environment Template
# Copy to .env.prod and fill ALL <CHANGE_ME> values before deploying.
# NEVER commit .env.prod to version control.
# ══════════════════════════════════════════════════════════════════════════════
# Quick-gen strong secrets:
#   SECRET_KEY:        python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   DB / Redis passwd: openssl rand -base64 32
# ── Copy this file to .env.prod and fill in real values before deploying ──────
# NEVER commit .env.prod to git

# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=pob_system
DATABASE_USER=pob_user
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Redis runs on the INTERNAL Docker network only (not published) and
# docker/redis.conf sets NO password, so REDIS_PASSWORD must be EMPTY to match —
# a non-empty value here makes the backend's AUTH fail against a passwordless
# Redis (symptoms: sse-ticket 503, broken notifications/session/rate-limit).
# To use a password instead: add `requirepass <pw>` to docker/redis.conf, then set
# the SAME value below and in REDIS_URL (redis://:<pw>@redis:6379/0).
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
API_V1_STR=/api/v1
PROJECT_NAME=POB System
VERSION=2.0.0
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS — set to your actual domain, e.g. https://pob.company.com
BACKEND_CORS_ORIGINS=["https://your-domain.com"]

# ZKTeco ADMS (device push — fill in if using ZKTeco cloud ADMS relay)
ZKTECO_ADMS_SERVER=https://adms.zkteco.com
ZKTECO_ADMS_PORT=443
ZKTECO_COMPANY_ID=
ZKTECO_ADMS_TOKEN=
ZKTECO_AUTO_REGISTER_DEVICES=True

# ZKTeco direct-IP connection (optional)
ZKTECO_API_BASE_URL=
ZKTECO_USERNAME=
ZKTECO_PASSWORD=
ZKTECO_TIMEOUT=30

# REQUIRED for auto-discovery of new/unconfigured readers when the backend runs
# in a container (which it does here). The container's own network interfaces
# are on the Docker bridge, NOT the customer's reader LAN — without this set,
# brand-new readers will never be found automatically (only readers manually
# added with a correct IP will be probed). Set to the actual reader LAN's
# CIDR, e.g.:
#   DEVICE_SCAN_SUBNETS=192.168.1.0/24
# Multiple ranges: comma-separated, e.g. 192.168.1.0/24,10.10.5.0/24
# Verify after deploy: GET /api/device/network-diagnostics
DEVICE_SCAN_SUBNETS=

# Allowed hosts (comma-separated; * for any)
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Grafana monitoring dashboard (accessible at https://your-domain.com/monitoring)
# Change these before deploying!
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Database backup directory
# Leave blank to use a local Docker volume (default).
# Set to your NAS mount point to store backups on a NAS drive, e.g.:
#   BACKUP_DIR=/mnt/nas-backups
# Make sure the NAS is mounted on the host BEFORE starting the containers.
# See: Settings → Database Backup → NAS Configuration Guide for mount instructions.
BACKUP_DIR=

# ── Security — MUST change before deploying ───────────────────────────────────
# Superuser bypass password — used for emergency global admin login.
# Must NOT be the default. Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
GLOBAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_GLOBAL_ADMIN_PASSWORD

# License signing secret — used to sign/verify subscription license tokens.
# Must NOT be the default to prevent unauthorized license generation.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
LICENSE_SECRET=CHANGE_ME_LICENSE_SECRET

# Emergency fire panel webhook key — optional; leave blank to disable.
# If set, only requests with X-Webhook-Key: <this value> can trigger emergency events.
EMERGENCY_WEBHOOK_KEY=

# ── Notification Channels ─────────────────────────────────────────────────────
# SMTP (email) — required for emergency email notifications to personnel
SMTP_HOST=smtp.your-mail-provider.com
SMTP_PORT=587
SMTP_USER=alerts@your-domain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=POB Emergency System <alerts@your-domain.com>
SMTP_TLS=True

# SMS gateway — required for emergency SMS to personnel during fire/gas alarm
# Format varies by provider (e.g. Twilio, Vonage, African SMS gateways)
SMS_API_URL=https://api.your-sms-provider.com/send
SMS_API_KEY=CHANGE_ME_SMS_API_KEY

# WhatsApp Business API — optional emergency channel
WHATSAPP_API_URL=https://api.your-whatsapp-provider.com/send
WHATSAPP_API_KEY=CHANGE_ME_WHATSAPP_API_KEY

# Firebase push notifications — optional mobile push channel
FCM_KEY=CHANGE_ME_FCM_SERVER_KEY

# ── Alertmanager (Prometheus → email alerts for BackendDown, DBDown, etc.) ───
# Configure the email address that receives production alerts from Prometheus.
ALERTMANAGER_EMAIL_FROM=alerts@your-domain.com
ALERTMANAGER_EMAIL_TO=oncall@your-domain.com
ALERTMANAGER_SMTP_HOST=smtp.your-mail-provider.com
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_USER=alerts@your-domain.com
ALERTMANAGER_SMTP_PASSWORD=CHANGE_ME_ALERTMANAGER_SMTP_PASSWORD
