# Copy this file to .env and fill in real values before running docker-compose.
# .env is gitignored — never commit it.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=pob_system
POSTGRES_USER=pob_user
POSTGRES_PASSWORD=change_me_in_production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be the same value set in backend/.env SECRET_KEY
SECRET_KEY=change_me_to_a_long_random_string

# ── Allowed hosts (comma-separated, used by TrustedHostMiddleware) ────────────
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS origins (comma-separated) ───────────────────────────────────────────
# Add your production domain here for deployment (localhost variants kept for dev)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Production example: BACKEND_CORS_ORIGINS=https://pob.yourcompany.com

# ── Email notifications (emergency + mustering alerts) ───────────────────────
# Fill these in and restart the backend to turn on email alerts. Empty = off
# (nothing sends). Gmail: create an App Password (Google account → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASSWORD.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
SMTP_USE_TLS=true

# ── SMS + WhatsApp (OFF by default) ──────────────────────────────────────────
# There is NO free cloud SMS/WhatsApp gateway — every provider charges to deliver.
# Leave SMS_PROVIDER empty to keep them off (email + in-app/PA alerts still work).
#
# Free/open-source routes are SELF-HOSTED and have caveats:
#   • SMS      → android-sms-gateway (Apache-2.0) on a phone+SIM, or Gammu+GSM modem.
#                Point SMS_API_URL at it and set SMS_PROVIDER=generic.
#   • WhatsApp → a Baileys / whatsapp-web.js gateway using your own number
#                (unofficial — Meta can ban it). Point WHATSAPP_API_URL at it.
# Paid options if you ever need them: SMS_PROVIDER=termii | twilio | africastalking.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=
SMS_CHANNEL=generic
SMS_DEFAULT_COUNTRY_CODE=234
TERMII_BASE_URL=https://api.ng.termii.com

WHATSAPP_PROVIDER=
WHATSAPP_SENDER_ID=

# Generic self-hosted HTTP gateway (POSTs {"api_key","to","message"}):
SMS_API_URL=
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Twilio (paid — only if SMS_PROVIDER=twilio):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM_NUMBER=
WHATSAPP_FROM=                     # e.g. whatsapp:+14155238886

# Africa's Talking (paid — only if SMS_PROVIDER=africastalking):
AT_USERNAME=
