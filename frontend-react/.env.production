# Production Environment Variables
NODE_ENV=production
GENERATE_SOURCEMAP=false
PUBLIC_URL=/pob-system

# API Configuration
# Left blank intentionally: the app uses RELATIVE URLs routed through nginx
# (see src/config/api.js → API_BASE_URL=''), so it works on any host/scheme
# (IP, DDNS hostname, or domain) over HTTP or HTTPS with no rebuild.
REACT_APP_API_URL=
REACT_APP_ENVIRONMENT=production

# Performance Optimizations
REACT_APP_DISABLE_SERVICE_WORKER=true
REACT_APP_INLINE_RUNTIME_CHUNK=false

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true
REACT_APP_ENABLE_ERROR_REPORTING=true

# Build Optimizations
REACT_APP_CHUNK_SIZE_WARNING_LIMIT=244000
REACT_APP_MAX_CHUNK_SIZE=512000

# Security
REACT_APP_API_TIMEOUT=10000
REACT_APP_RETRY_ATTEMPTS=3
REACT_APP_RETRY_DELAY=1000

# WebSocket Configuration
# Left blank intentionally: WebSocket URLs are derived at runtime from
# window.location (wss:// on HTTPS) and routed through nginx — never hardcoded.
REACT_APP_WEBSOCKET_URL=
REACT_APP_WEBSOCKET_RECONNECT_ATTEMPTS=5
REACT_APP_WEBSOCKET_RECONNECT_DELAY=1000

# Error Tracking
REACT_APP_ERROR_TRACKING_URL=
REACT_APP_ERROR_TRACKING_KEY=
