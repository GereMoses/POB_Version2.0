# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/pob_system
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pob_system
DATABASE_USER=username
DATABASE_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=POB System
VERSION=2.0.0
DESCRIPTION=Personnel On Board Management System for Oil & Gas Operations

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# ZKTeco Configuration
ZKTECO_API_BASE_URL=http://localhost:8088
ZKTECO_USERNAME=admin
ZKTECO_PASSWORD=password
ZKTECO_TIMEOUT=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Development/Production
DEBUG=True
ENVIRONMENT=development
